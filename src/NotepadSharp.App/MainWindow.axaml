<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:NotepadSharp.Core;assembly=NotepadSharp.Core"
    xmlns:vm="clr-namespace:NotepadSharp.App.ViewModels"
    xmlns:app="clr-namespace:NotepadSharp.App"
    xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NotepadSharp.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="720" MinHeight="480"
        Title="{Binding WindowTitle}"
        WindowState="Maximized"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome,OSXThickTitleBar"
        ExtendClientAreaTitleBarHeightHint="44"
        Icon="/Assets/notepadsharp-icon-white.png"
        DragDrop.AllowDrop="True"
        DragDrop.DragOver="OnWindowDragOver"
        DragDrop.Drop="OnWindowDrop">

    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackdropBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#0F1620" />
            <GradientStop Offset="0.55" Color="#0C121A" />
            <GradientStop Offset="1.0" Color="#090F15" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="ChromePanelBrush" Color="#161F2A" />
        <SolidColorBrush x:Key="ChromePanelAltBrush" Color="#121B25" />
        <SolidColorBrush x:Key="MenuBarBrush" Color="#161F2A" />
        <SolidColorBrush x:Key="ChromeBorderBrush" Color="#2C3B4A" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#79BDD8" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#446E86" />
        <SolidColorBrush x:Key="MenuTextBrush" Color="#E6EDF3" />
        <SolidColorBrush x:Key="TopNavTextBrush" Color="#F2F7FC" />
        <SolidColorBrush x:Key="MenuIconBrush" Color="#A9C3D8" />
        <SolidColorBrush x:Key="ToolbarSurfaceBrush" Color="#111B29" />
        <SolidColorBrush x:Key="ToolbarButtonBrush" Color="#152234" />
        <SolidColorBrush x:Key="ToolbarButtonHoverBrush" Color="#1F3348" />
        <SolidColorBrush x:Key="ToolbarButtonPressedBrush" Color="#142537" />
        <SolidColorBrush x:Key="ToolbarButtonTextBrush" Color="#E8F1F8" />
        <SolidColorBrush x:Key="ToolbarIconBrush" Color="#9CC6E3" />
        <SolidColorBrush x:Key="QuickPickerBrush" Color="#132133" />
        <SolidColorBrush x:Key="QuickPickerHoverBrush" Color="#1D3044" />
        <SolidColorBrush x:Key="QuickPickerTextBrush" Color="#E6EDF3" />
        <SolidColorBrush x:Key="StatusPickerBrush" Color="#152232" />
        <SolidColorBrush x:Key="StatusPickerHoverBrush" Color="#1D3044" />
        <SolidColorBrush x:Key="StatusPickerTextBrush" Color="#E6EDF3" />
        <SolidColorBrush x:Key="TabBackgroundBrush" Color="#1A2A3A" />
        <SolidColorBrush x:Key="TabHoverBrush" Color="#1F2C3A" />
        <SolidColorBrush x:Key="TabSelectedBrush" Color="#27435A" />
        <SolidColorBrush x:Key="TabTextBrush" Color="#E6EDF3" />
        <SolidColorBrush x:Key="ActivityRailBrush" Color="#131F2D" />
        <SolidColorBrush x:Key="SidebarNavBrush" Color="#162434" />
        <SolidColorBrush x:Key="SidebarNavHoverBrush" Color="#1F3348" />
        <SolidColorBrush x:Key="SidebarNavCheckedBrush" Color="#26455E" />
        <SolidColorBrush x:Key="TabCloseDangerBrush" Color="{DynamicResource ErrorText}" Opacity="0.85" />
        <SolidColorBrush x:Key="TabCloseDangerBrushHover" Color="{DynamicResource ErrorText}" Opacity="1" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="MenuItem">
            <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{DynamicResource MenuTextBrush}" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style Selector="MenuItem.top-nav">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{DynamicResource TopNavTextBrush}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="mi|MaterialIcon.menu-icon">
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource MenuIconBrush}" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="MaxWidth" Value="260" />
            <Setter Property="Background" Value="{DynamicResource TabBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TabTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10,10,0,0">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabItem:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="Background" Value="{DynamicResource TabHoverBrush}" />
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource TabSelectedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TabItem:pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
        </Style>

        <Style Selector="ae|TextEditor.editor">
            <Setter Property="Background" Value="#0F1722" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="TextBox.search-input">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#0F1720" />
            <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style Selector="Button.find-action">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="Background" Value="#1A2A39" />
        </Style>

        <Style Selector="Button.find-action:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="Background" Value="#254258" />
        </Style>

        <Style Selector="CheckBox.find-option">
            <Setter Property="Margin" Value="0,1,0,1" />
        </Style>

        <Style Selector="ComboBox.status-language-picker">
            <Setter Property="MinWidth" Value="138" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="{DynamicResource StatusPickerBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource StatusPickerTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="ComboBox.status-language-picker:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="Background" Value="{DynamicResource StatusPickerHoverBrush}" />
        </Style>

        <Style Selector="ComboBoxItem.language-option">
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="Button.quick-chip">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ToolbarButtonTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.quick-chip:pointerover">
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
        </Style>

        <Style Selector="Button.quick-chip:pressed">
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonPressedBrush}" />
        </Style>

        <Style Selector="ComboBox.quick-picker">
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="{DynamicResource QuickPickerBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource QuickPickerTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="ComboBox.quick-picker:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="Background" Value="{DynamicResource QuickPickerHoverBrush}" />
        </Style>

        <Style Selector="WrapPanel#QuickToolbarWrapPanel > Button.quick-chip">
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style Selector="WrapPanel#QuickToolbarWrapPanel > Button.sidebar-action">
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style Selector="WrapPanel#QuickToolbarWrapPanel > ComboBox.quick-picker">
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style Selector="WrapPanel#QuickToolbarWrapPanel > CheckBox">
            <Setter Property="Margin" Value="0,0,10,6" />
        </Style>

        <Style Selector="ComboBox.tab-overflow-picker">
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="{DynamicResource QuickPickerBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource QuickPickerTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="ComboBox.tab-overflow-picker:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="Background" Value="{DynamicResource QuickPickerHoverBrush}" />
        </Style>

        <Style Selector="ToggleButton.sidebar-nav">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource SidebarNavBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="ToggleButton.sidebar-nav:pointerover">
            <Setter Property="Background" Value="{DynamicResource SidebarNavHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
        </Style>

        <Style Selector="ToggleButton.sidebar-nav:checked">
            <Setter Property="Background" Value="{DynamicResource SidebarNavCheckedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
        </Style>

        <Style Selector="TextBox.sidebar-input">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{DynamicResource ChromePanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.sidebar-action">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.sidebar-action:pointerover">
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
        </Style>

        <Style Selector="Button.git-toolbar">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="7,1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.git-toolbar:pointerover">
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}" />
        </Style>

        <Style Selector="Button.git-toolbar.icon">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="24" />
        </Style>

        <Style Selector="TextBlock.sidebar-meta">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Margin" Value="0,1,0,1" />
        </Style>

        <Style Selector="Button.tab-close">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#6E313A" />
            <Setter Property="Foreground" Value="#FFEFF1" />
            <Setter Property="BorderBrush" Value="#AE4B59" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.tab-close:pointerover">
            <Setter Property="Background" Value="#8C3A46" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D36B78" />
        </Style>

        <Style Selector="Button.tab-close:pressed">
            <Setter Property="Background" Value="#5D2932" />
        </Style>
    </Window.Styles>

    <DockPanel x:Name="RootDockPanel" Background="{DynamicResource WindowBackdropBrush}">
        <Border x:Name="WindowDragStrip"
                DockPanel.Dock="Top"
                Height="10"
                Background="Transparent"
                PointerPressed="OnWindowDragStripPointerPressed" />

        <Border x:Name="MenuBarHostBorder"
                DockPanel.Dock="Top"
                Margin="8,2,8,0"
                Padding="2"
                CornerRadius="12"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ChromeBorderBrush}"
                Background="{DynamicResource MenuBarBrush}"
                PointerPressed="OnTopChromePointerPressed">
            <Menu>
            <MenuItem Classes="top-nav" Header="_File">
                <MenuItem Header="_New (Ctrl/Cmd+N)" Click="OnNewClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FilePlusOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Open... (Ctrl/Cmd+O)" Click="OnOpenClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FolderOpenOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Quick Open... (Ctrl/Cmd+P)" Click="OnQuickOpenClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="Magnify" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="OpenRecentMenuItem" Header="Open _Recent">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="History" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Save (Ctrl/Cmd+S)" Click="OnSaveClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ContentSaveOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Save _As... (Ctrl/Cmd+Shift+S)" Click="OnSaveAsClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ContentSaveEditOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Save A_ll (Ctrl/Cmd+Alt+S)" Click="OnSaveAllClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ContentSaveAllOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Close Tab (Ctrl/Cmd+W)" Click="OnCloseTabClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="Close" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Close A_ll Tabs" Click="OnCloseAllTabsClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="TabMinus" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Reopen Closed _Tab (Ctrl/Cmd+Shift+T)" Click="OnReopenClosedTabClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="TabPlus" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="E_xit" Click="OnExitClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ExitRun" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Classes="top-nav" Header="_Edit">
                <MenuItem Header="_Undo (Ctrl/Cmd+Z)" Click="OnUndoClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="UndoVariant" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Redo (Ctrl+Y / Ctrl/Cmd+Shift+Z)" Click="OnRedoClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="RedoVariant" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Command _Palette... (Ctrl/Cmd+Shift+P)" Click="OnCommandPaletteClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="LightbulbOnOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="S_mart Actions... (Ctrl/Cmd+K)" Click="OnShowAiAssistantClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="CreationOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Cu_t (Ctrl/Cmd+X)" Click="OnCutClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ContentCut" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Copy (Ctrl/Cmd+C)" Click="OnCopyClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ContentCopy" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Paste (Ctrl/Cmd+V)" Click="OnPasteClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ContentPaste" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Select _All (Ctrl/Cmd+A)" Click="OnSelectAllClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="SelectAll" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Duplicate Line/Selection (Ctrl/Cmd+D)" Click="OnDuplicateClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ContentDuplicate" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Delete Line (Ctrl/Cmd+Shift+K)" Click="OnDeleteLineClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="DeleteOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="UPPERCASE" Click="OnUppercaseClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FormatLetterCaseUpper" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="lowercase" Click="OnLowercaseClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FormatLetterCaseLower" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Find... (Ctrl/Cmd+F)" Click="OnShowFindClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="Magnify" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Replace... (Ctrl/Cmd+H)" Click="OnShowReplaceClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FindReplace" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Search in _Files... (Ctrl/Cmd+Shift+F)" Click="OnShowSearchInFilesClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FileSearchOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Replace in Fi_les..." Click="OnReplaceInFilesMenuClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FileReplaceOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Rename Symbol... (F2)" Click="OnRenameSymbolClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="RenameBox" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Go To Line... (Ctrl/Cmd+G)" Click="OnGoToLineClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FormatListNumbered" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Go To _Symbol... (Ctrl/Cmd+Shift+O)" Click="OnGoToSymbolClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="CodeBraces" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Go To _Workspace Symbol... (Ctrl/Cmd+T)" Click="OnGoToWorkspaceSymbolClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FileSearchOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Go To _Definition (F12)" Click="OnGoToDefinitionClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="CodeBraces" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Find _References (Shift+F12)" Click="OnFindReferencesClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FileSearchOutline" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Next Git Change (F7)" Click="OnNextGitChangeClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="SourceBranchPlus" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Previous Git Change (Shift+F7)" Click="OnPreviousGitChangeClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="SourceBranchMinus" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Go To _Matching Bracket (Ctrl/Cmd+])" Click="OnGoToMatchingBracketClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="CodeBrackets" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Classes="top-nav" Header="F_ormat">
                <MenuItem.Icon>
                    <mi:MaterialIcon Classes="menu-icon" Kind="FormatText" />
                </MenuItem.Icon>
                <MenuItem Header="Line _Endings">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="SwapVertical" />
                    </MenuItem.Icon>
                    <MenuItem Header="LF" Click="OnSetLineEndingLfClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="KeyboardReturn" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="CRLF" Click="OnSetLineEndingCrLfClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="KeyboardReturn" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="CR" Click="OnSetLineEndingCrClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="KeyboardReturn" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="_Encoding">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="CodeTags" />
                    </MenuItem.Icon>
                    <MenuItem Header="UTF-8" Click="OnSetEncodingUtf8Click">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="CodeJson" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="UTF-8 (BOM)" Click="OnSetEncodingUtf8BomClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="CodeTagsCheck" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="UTF-16 LE" Click="OnSetEncodingUtf16LeClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="CodeBraces" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="UTF-16 BE" Click="OnSetEncodingUtf16BeClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="CodeBracesBox" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="_Language">
                    <MenuItem Header="Auto Detect" Click="OnSetLanguageAutoClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="CreationOutline" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Plain Text" Click="OnSetLanguagePlainTextClick" />
                    <MenuItem Header="C#" Click="OnSetLanguageCSharpClick" />
                    <MenuItem Header="JSON" Click="OnSetLanguageJsonClick" />
                    <MenuItem Header="XML" Click="OnSetLanguageXmlClick" />
                    <MenuItem Header="YAML" Click="OnSetLanguageYamlClick" />
                    <MenuItem Header="Markdown" Click="OnSetLanguageMarkdownClick" />
                    <MenuItem Header="JavaScript" Click="OnSetLanguageJavaScriptClick" />
                    <MenuItem Header="TypeScript" Click="OnSetLanguageTypeScriptClick" />
                    <MenuItem Header="Python" Click="OnSetLanguagePythonClick" />
                    <MenuItem Header="SQL" Click="OnSetLanguageSqlClick" />
                    <MenuItem Header="HTML" Click="OnSetLanguageHtmlClick" />
                    <MenuItem Header="CSS" Click="OnSetLanguageCssClick" />
                </MenuItem>

                <Separator />

                <MenuItem Header="Format _Document (Shift+Alt+F)" Click="OnFormatDocumentClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="CodeBraces" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Format _Selection" Click="OnFormatSelectionClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="CodeArray" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem Header="Word _Wrap" ToggleType="CheckBox" IsChecked="{Binding SelectedDocument.WordWrap, Mode=TwoWay}" Click="OnToggleWordWrapClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Wrap" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Column _Guide">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="FormatVerticalAlignCenter" />
                    </MenuItem.Icon>
                    <MenuItem x:Name="ColumnGuideOffMenuItem" Header="_Off" ToggleType="CheckBox" Click="OnColumnGuideOffClick" />
                    <Separator />
                    <MenuItem x:Name="ColumnGuide80MenuItem" Header="_80" ToggleType="CheckBox" Click="OnColumnGuide80Click" />
                    <MenuItem x:Name="ColumnGuide100MenuItem" Header="_100" ToggleType="CheckBox" Click="OnColumnGuide100Click" />
                    <MenuItem x:Name="ColumnGuide120MenuItem" Header="_120" ToggleType="CheckBox" Click="OnColumnGuide120Click" />
                </MenuItem>

                <Separator />

                <MenuItem Header="_Zoom">
                    <MenuItem Header="Zoom _In (Ctrl/Cmd++)" Click="OnZoomInClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="MagnifyPlusOutline" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Zoom _Out (Ctrl/Cmd+-)" Click="OnZoomOutClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="MagnifyMinusOutline" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_Reset Zoom (Ctrl/Cmd+0)" Click="OnZoomResetClick">
                        <MenuItem.Icon>
                            <mi:MaterialIcon Classes="menu-icon" Kind="MagnifyClose" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </MenuItem>

            <MenuItem Classes="top-nav" Header="_View">
                <MenuItem x:Name="SplitViewMenuItem"
                          Header="Toggle _Split Editor (Ctrl/Cmd+\\)"
                          ToggleType="CheckBox"
                          IsChecked="False"
                          Click="OnToggleSplitViewClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ViewSplitVertical" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Split With _Next Tab" Click="OnSplitWithNextTabClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="TabSearch" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem x:Name="MiniMapMenuItem" Header="_Mini Map" ToggleType="CheckBox" IsChecked="True" Click="OnToggleMiniMapClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="MapLegend" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="TerminalMenuItem" Header="_Shell Session (Ctrl/Cmd+`)" ToggleType="CheckBox" IsChecked="False" Click="OnToggleTerminalClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="ConsoleLine" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="TerminalInterruptMenuItem" Header="Interrupt Shell Command" Click="OnTerminalInterruptClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="Cancel" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="MaximizeEditorMenuItem"
                          Header="_Maximize Editor (F11)"
                          ToggleType="CheckBox"
                          IsChecked="False"
                          Click="OnToggleEditorMaximizeClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="Fullscreen" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem x:Name="ShowTabBarMenuItem" Header="Show _Tab Bar" ToggleType="CheckBox" IsChecked="True" Click="OnToggleTabBarClick" />
                <MenuItem x:Name="AutoHideTabBarMenuItem" Header="_Auto Hide Tab Bar" ToggleType="CheckBox" IsChecked="False" Click="OnToggleAutoHideTabBarClick" />
                <Separator />
                <MenuItem Header="_Theme">
                    <MenuItem x:Name="ThemeDarkPlusMenuItem" Header="Dark+" ToggleType="CheckBox" Click="OnThemeDarkPlusClick" />
                    <MenuItem x:Name="ThemeOneDarkMenuItem" Header="One Dark" ToggleType="CheckBox" Click="OnThemeOneDarkClick" />
                    <MenuItem x:Name="ThemeMonokaiMenuItem" Header="Monokai" ToggleType="CheckBox" Click="OnThemeMonokaiClick" />
                    <MenuItem x:Name="ThemeLightMenuItem" Header="Light" ToggleType="CheckBox" Click="OnThemeLightClick" />
                </MenuItem>
                <Separator />
                <MenuItem Header="_Folding">
                    <MenuItem x:Name="FoldingEnabledMenuItem" Header="Enable Folding" ToggleType="CheckBox" IsChecked="True" Click="OnToggleFoldingClick" />
                    <MenuItem Header="Fold _All" Click="OnFoldAllClick" />
                    <MenuItem Header="Unfold A_ll" Click="OnUnfoldAllClick" />
                </MenuItem>
            </MenuItem>

            <MenuItem Classes="top-nav" Header="_Help">
                <MenuItem Header="Keyboard _Shortcuts (F1 / Ctrl/Cmd+/)" Click="OnKeyboardShortcutsClick">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Classes="menu-icon" Kind="Keyboard" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            </Menu>
        </Border>

        <Border x:Name="QuickToolbarHostBorder"
                DockPanel.Dock="Top"
                Margin="8,2,8,0"
                Padding="8,4"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="{DynamicResource ChromeBorderBrush}"
                Background="{DynamicResource ToolbarSurfaceBrush}"
                PointerPressed="OnTopChromePointerPressed">
            <WrapPanel x:Name="QuickToolbarWrapPanel"
                       Orientation="Horizontal"
                       VerticalAlignment="Center">
                    <Button Classes="quick-chip" Click="OnNewClick" ToolTip.Tip="New (Ctrl/Cmd+N)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="FilePlusOutline" />
                            <TextBlock Text="New" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnOpenClick" ToolTip.Tip="Open (Ctrl/Cmd+O)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="FolderOpenOutline" />
                            <TextBlock Text="Open" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnSaveClick" ToolTip.Tip="Save (Ctrl/Cmd+S)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="ContentSaveOutline" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnShowFindClick" ToolTip.Tip="Find (Ctrl/Cmd+F)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="Magnify" />
                            <TextBlock Text="Find" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnCommandPaletteClick" ToolTip.Tip="Command Palette (Ctrl/Cmd+Shift+P)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="LightbulbOnOutline" />
                            <TextBlock Text="Palette" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnShowAiAssistantClick" ToolTip.Tip="Smart Actions (Ctrl/Cmd+K)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="CreationOutline" />
                            <TextBlock Text="Smart" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnShowSearchInFilesClick" ToolTip.Tip="Search in Files (Ctrl/Cmd+Shift+F)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="FileSearchOutline" />
                            <TextBlock Text="Files" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnToolbarSplitClick" ToolTip.Tip="Split with next tab (click again to close split)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="ViewSplitVertical" />
                            <TextBlock Text="Split" />
                        </StackPanel>
                    </Button>
                    <Button Classes="quick-chip" Click="OnToggleMiniMapClick" ToolTip.Tip="Toggle mini map">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="MapLegend" />
                            <TextBlock Text="Map" />
                        </StackPanel>
                    </Button>
                    <ComboBox x:Name="SplitCompareModeComboBox"
                              Classes="quick-picker"
                              MinWidth="142"
                              SelectionChanged="OnSplitCompareModeSelectionChanged"
                              ToolTip.Tip="Compare mode for split editors">
                        <ComboBoxItem Content="Compare" />
                        <ComboBoxItem Content="Show diff only" />
                        <ComboBoxItem Content="Show all" />
                    </ComboBox>
                    <Button x:Name="SplitComparePrevButton"
                            Classes="quick-chip"
                            Click="OnSplitComparePrevClick"
                            ToolTip.Tip="Previous change in split compare">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="ChevronUp" />
                            <TextBlock Text="Prev" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SplitCompareNextButton"
                            Classes="quick-chip"
                            Click="OnSplitCompareNextClick"
                            ToolTip.Tip="Next change in split compare">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="ChevronDown" />
                            <TextBlock Text="Next" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar-action" Click="OnOpenWorkspaceClick" ToolTip.Tip="Open Workspace Folder">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Width="14" Height="14" Foreground="{DynamicResource ToolbarIconBrush}" Kind="FolderCogOutline" />
                            <TextBlock Text="Workspace" />
                        </StackPanel>
                    </Button>
                    <ComboBox x:Name="EditorFontFamilyComboBox"
                              Classes="quick-picker"
                              MinWidth="138"
                              SelectionChanged="OnEditorFontFamilySelectionChanged"
                              ToolTip.Tip="Editor font family">
                        <ComboBoxItem Content="Consolas" />
                        <ComboBoxItem Content="Cascadia Mono" />
                        <ComboBoxItem Content="JetBrains Mono" />
                        <ComboBoxItem Content="Fira Code" />
                        <ComboBoxItem Content="Menlo" />
                        <ComboBoxItem Content="Monaco" />
                        <ComboBoxItem Content="Courier New" />
                        <ComboBoxItem Content="Source Code Pro" />
                    </ComboBox>
                    <ComboBox x:Name="EditorFontSizeComboBox"
                              Classes="quick-picker"
                              MinWidth="70"
                              SelectionChanged="OnEditorFontSizeSelectionChanged"
                              ToolTip.Tip="Editor font size">
                        <ComboBoxItem Content="10" />
                        <ComboBoxItem Content="11" />
                        <ComboBoxItem Content="12" />
                        <ComboBoxItem Content="13" />
                        <ComboBoxItem Content="14" />
                        <ComboBoxItem Content="15" />
                        <ComboBoxItem Content="16" />
                        <ComboBoxItem Content="18" />
                        <ComboBoxItem Content="20" />
                        <ComboBoxItem Content="24" />
                    </ComboBox>
                    <CheckBox x:Name="ToolbarShowAllCharactersCheckBox"
                              VerticalAlignment="Center"
                              Content="Chars"
                              Click="OnToolbarShowAllCharactersClick"
                              ToolTip.Tip="Show all characters (spaces, tabs, line endings)" />
                    <ComboBox x:Name="ThemeModeComboBox"
                              Classes="quick-picker"
                              MinWidth="116"
                              SelectionChanged="OnThemeModeSelectionChanged"
                              ToolTip.Tip="Theme">
                        <ComboBoxItem Content="Dark+" />
                        <ComboBoxItem Content="One Dark" />
                        <ComboBoxItem Content="Monokai" />
                        <ComboBoxItem Content="Light" />
                    </ComboBox>
                    <Button x:Name="EditorMaximizeButton" Classes="quick-chip" Click="OnToggleEditorMaximizeClick" ToolTip.Tip="Maximize editor (F11)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon x:Name="EditorMaximizeButtonIcon"
                                             Width="14"
                                             Height="14"
                                             Foreground="{DynamicResource ToolbarIconBrush}"
                                             Kind="Fullscreen" />
                            <TextBlock x:Name="EditorMaximizeButtonText" Text="Max" />
                        </StackPanel>
                    </Button>
            </WrapPanel>
        </Border>

        <Border x:Name="StatusBarHostBorder"
                DockPanel.Dock="Bottom"
                Margin="8,0,8,8"
                Padding="10,8"
                CornerRadius="10"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ChromeBorderBrush}"
                Background="{DynamicResource ChromePanelBrush}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <mi:MaterialIcon Kind="CursorText" Width="14" Height="14" Opacity="0.7" />
                    <TextBlock FontSize="12" Opacity="0.9" Text="{Binding StatusCaret}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="CodeTags" Width="14" Height="14" Opacity="0.7" />
                        <TextBlock FontSize="12" Opacity="0.9" VerticalAlignment="Center" Text="{Binding StatusFormat}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14" Opacity="0.7" />
                        <TextBlock x:Name="StatusDiagnosticsTextBlock" FontSize="12" Opacity="0.9" VerticalAlignment="Center" Text="Diagnostics: 0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="Speedometer" Width="14" Height="14" Opacity="0.7" />
                        <TextBlock x:Name="StatusPerfTextBlock"
                                   FontSize="11"
                                   Opacity="0.82"
                                   VerticalAlignment="Center"
                                   Text="open -- | style -- | fold -- | diff --" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="FileCodeOutline" Width="14" Height="14" Opacity="0.7" />
                        <ComboBox x:Name="LanguageModeComboBox"
                                  Classes="status-language-picker"
                                  SelectionChanged="OnLanguageModeSelectionChanged"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Language mode">
                            <ComboBoxItem Classes="language-option" Content="Auto" />
                            <ComboBoxItem Classes="language-option" Content="Plain Text" />
                            <ComboBoxItem Classes="language-option" Content="C#" />
                            <ComboBoxItem Classes="language-option" Content="JSON" />
                            <ComboBoxItem Classes="language-option" Content="XML" />
                            <ComboBoxItem Classes="language-option" Content="YAML" />
                            <ComboBoxItem Classes="language-option" Content="Markdown" />
                            <ComboBoxItem Classes="language-option" Content="JavaScript" />
                            <ComboBoxItem Classes="language-option" Content="TypeScript" />
                            <ComboBoxItem Classes="language-option" Content="Python" />
                            <ComboBoxItem Classes="language-option" Content="SQL" />
                            <ComboBoxItem Classes="language-option" Content="HTML" />
                            <ComboBoxItem Classes="language-option" Content="CSS" />
                        </ComboBox>
                        <TextBlock FontSize="12" Opacity="0.72" VerticalAlignment="Center" Text="{Binding StatusLanguage}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top"
                Margin="8,8,8,0"
                Padding="12"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="{DynamicResource ChromeBorderBrush}"
                Background="{DynamicResource ChromePanelAltBrush}"
                IsVisible="{Binding IsFindReplaceVisible}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Find" />
                <TextBox x:Name="FindTextBox" Classes="search-input" Grid.Row="0" Grid.Column="1" Watermark="Find" Text="{Binding FindText, Mode=TwoWay}" />
                <Button Classes="find-action" Grid.Row="0" Grid.Column="2" Content="Prev" Click="OnFindPrevClick" />
                <Button Classes="find-action" Grid.Row="0" Grid.Column="3" Content="Next" Click="OnFindNextClick" />
                <Button Classes="find-action" Grid.Row="0" Grid.Column="4" Content="Close" Click="OnHideFindReplaceClick" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Replace" IsVisible="{Binding IsReplaceVisible}" />
                <TextBox x:Name="ReplaceTextBox" Classes="search-input" Grid.Row="1" Grid.Column="1" Watermark="Replace" Text="{Binding ReplaceText, Mode=TwoWay}" IsVisible="{Binding IsReplaceVisible}" />
                <Button Classes="find-action" Grid.Row="1" Grid.Column="2" Content="Replace" Click="OnReplaceClick" IsVisible="{Binding IsReplaceVisible}" />
                <Button Classes="find-action" Grid.Row="1" Grid.Column="3" Content="Replace All" Click="OnReplaceAllClick" IsVisible="{Binding IsReplaceVisible}" />
                <StackPanel Grid.Row="1" Grid.Column="4" Spacing="6">
                    <CheckBox Classes="find-option" Content="Match case" IsChecked="{Binding MatchCase, Mode=TwoWay}" />
                    <CheckBox Classes="find-option" Content="Whole word" IsChecked="{Binding WholeWord, Mode=TwoWay}" />
                    <CheckBox Classes="find-option" Content="Regex" IsChecked="{Binding UseRegex, Mode=TwoWay}" />
                    <CheckBox Classes="find-option" Content="Wrap" IsChecked="{Binding WrapAround, Mode=TwoWay}" />
                    <CheckBox Classes="find-option" Content="In selection" IsChecked="{Binding InSelection, Mode=TwoWay}" />
                </StackPanel>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           FontSize="12"
                           Opacity="0.72"
                           Text="{Binding FindSummary}" />
            </Grid>
        </Border>

        <Border x:Name="EditorSurfaceBorder"
                Margin="8,0,8,8"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource ChromeBorderBrush}"
                Background="{DynamicResource ChromePanelAltBrush}">
            <Grid RowDefinitions="Auto,*,6,180" ClipToBounds="True">
                <Grid x:Name="TabStripLayoutGrid"
                      Grid.Row="0"
                      ColumnDefinitions="340,6,Auto,*,Auto"
                      ClipToBounds="True"
                      SizeChanged="OnTabStripLayoutGridSizeChanged">
                    <Border x:Name="TabStripSidebarSpacer"
                            Grid.Column="0"
                            BorderThickness="0,0,1,1"
                            BorderBrush="{DynamicResource ChromeBorderBrush}"
                            Background="{DynamicResource ChromePanelBrush}" />
                    <Border Grid.Column="1"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource ChromeBorderBrush}"
                            Background="#233545" />

                    <Grid x:Name="DocumentTabsHostGrid"
                          Grid.Column="2"
                          Grid.ColumnSpan="3"
                          Margin="0,2,8,0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <TabControl x:Name="DocumentTabs"
                                    Grid.Column="0"
                                    ItemsSource="{Binding Documents}"
                                    SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                                    SelectionChanged="OnDocumentTabsSelectionChanged">
                            <TabControl.ItemTemplate>
                                <DataTemplate x:DataType="core:TextDocument">
                                    <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                        <TextBlock DockPanel.Dock="Left"
                                                   MaxWidth="220"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.95"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding DisplayName}" />
                                        <Button DockPanel.Dock="Right"
                                                Classes="tab-close"
                                                ToolTip.Tip="Close"
                                                Tag="{Binding}"
                                                Margin="6,0,0,0"
                                                Click="OnCloseTabButtonClick">
                                            <mi:MaterialIcon Kind="Close"
                                                             Width="10"
                                                             Height="10"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>

                            <TabControl.ContentTemplate>
                                <DataTemplate>
                                    <Border Height="0" />
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>

                        <ComboBox x:Name="TabOverflowComboBox"
                                  Grid.Column="1"
                                  Classes="tab-overflow-picker"
                                  ItemsSource="{Binding Documents}"
                                  SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                                  SelectionChanged="OnTabOverflowSelectionChanged"
                                  ToolTip.Tip="Select from all open tabs">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="core:TextDocument">
                                    <TextBlock MaxWidth="280"
                                               Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Grid>

                <Grid x:Name="EditorLayoutGrid" Grid.Row="1" ColumnDefinitions="340,6,Auto,*,Auto" ClipToBounds="False">
                    <Border x:Name="SidebarHostBorder"
                            Grid.Column="0"
                            Padding="0"
                            BorderThickness="0,0,1,0"
                            BorderBrush="{DynamicResource ChromeBorderBrush}"
                            Background="{DynamicResource ChromePanelBrush}"
                            PointerEntered="OnSidebarHostPointerEntered"
                            PointerExited="OnSidebarHostPointerExited">
                        <Grid ColumnDefinitions="44,*" ClipToBounds="True">
                            <Border Grid.Column="0"
                                    Padding="6"
                                    BorderThickness="0,0,1,0"
                                    BorderBrush="{DynamicResource ChromeBorderBrush}"
                                    Background="{DynamicResource ActivityRailBrush}">
                                <StackPanel Spacing="6">
                                    <ToggleButton x:Name="SidebarExplorerButton" Classes="sidebar-nav" IsChecked="True" Click="OnSidebarExplorerClick" ToolTip.Tip="Explorer">
                                        <mi:MaterialIcon Kind="FolderOutline" Width="16" Height="16" />
                                    </ToggleButton>
                                    <ToggleButton x:Name="SidebarSearchButton" Classes="sidebar-nav" Click="OnSidebarSearchClick" ToolTip.Tip="Search in files">
                                        <mi:MaterialIcon Kind="Magnify" Width="16" Height="16" />
                                    </ToggleButton>
                                    <ToggleButton x:Name="SidebarSourceControlButton" Classes="sidebar-nav" Click="OnSidebarSourceControlClick" ToolTip.Tip="Source Control">
                                        <mi:MaterialIcon Kind="SourceBranch" Width="16" Height="16" />
                                    </ToggleButton>
                                    <ToggleButton x:Name="SidebarDiagnosticsButton" Classes="sidebar-nav" Click="OnSidebarDiagnosticsClick" ToolTip.Tip="Diagnostics">
                                        <mi:MaterialIcon Kind="AlertCircleOutline" Width="16" Height="16" />
                                    </ToggleButton>
                                    <ToggleButton x:Name="SidebarAiButton" Classes="sidebar-nav" Click="OnSidebarAiAssistantClick" ToolTip.Tip="Smart Actions">
                                        <mi:MaterialIcon Kind="CreationOutline" Width="16" Height="16" />
                                    </ToggleButton>
                                    <ToggleButton x:Name="SidebarSettingsButton" Classes="sidebar-nav" Click="OnSidebarSettingsClick" ToolTip.Tip="Settings">
                                        <mi:MaterialIcon Kind="CogOutline" Width="16" Height="16" />
                                    </ToggleButton>
                                    <Separator Margin="0,4,0,4" />
                                    <ToggleButton x:Name="SidebarAutoHideToggleButton"
                                                  Classes="sidebar-nav"
                                                  Click="OnSidebarAutoHideToggleClick"
                                                  ToolTip.Tip="Auto-hide sidebar pane">
                                        <mi:MaterialIcon Kind="PinOutline" Width="16" Height="16" />
                                    </ToggleButton>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SidebarPaneHost"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="{DynamicResource ChromePanelBrush}">
                                <Grid>
                                    <Grid x:Name="ExplorerPane" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Classes="sidebar-action" Content="Open Folder" Click="OnOpenWorkspaceClick" />
                                            <Button Classes="sidebar-action" Content="Refresh" Click="OnRefreshWorkspaceClick" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                                            <Button Classes="sidebar-action" Content="New File" Click="OnExplorerNewFileClick" />
                                            <Button Classes="sidebar-action" Content="New Folder" Click="OnExplorerNewFolderClick" />
                                        </StackPanel>
                                        <TextBlock x:Name="WorkspaceRootTextBlock"
                                                   Grid.Row="2"
                                                   Classes="sidebar-meta"
                                                   Text="No workspace loaded." />
                                        <TreeView x:Name="ExplorerTreeView"
                                                  Grid.Row="3"
                                                  SelectionChanged="OnExplorerTreeSelectionChanged"
                                                  Tapped="OnExplorerTreeTapped"
                                                  DoubleTapped="OnExplorerTreeDoubleTapped"
                                                  DragDrop.AllowDrop="True"
                                                  DragDrop.DragOver="OnExplorerTreeDragOver"
                                                  DragDrop.Drop="OnExplorerTreeDrop"
                                                  ToolTip.Tip="Double click a file to open">
                                            <TreeView.Styles>
                                                <Style Selector="TreeViewItem">
                                                    <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                                                </Style>
                                            </TreeView.Styles>
                                            <TreeView.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="New File" Click="OnExplorerNewFileClick" />
                                                    <MenuItem Header="New Folder" Click="OnExplorerNewFolderClick" />
                                                    <Separator />
                                                    <MenuItem Header="Rename" Click="OnExplorerRenameClick" />
                                                    <MenuItem Header="Delete" Click="OnExplorerDeleteClick" />
                                                </ContextMenu>
                                            </TreeView.ContextMenu>
                                            <TreeView.ItemTemplate>
                                                <TreeDataTemplate x:DataType="app:ExplorerTreeNode"
                                                                  ItemsSource="{Binding Children}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <mi:MaterialIcon Width="14" Height="14" Kind="{Binding IconKind}" />
                                                        <TextBlock FontSize="12" Text="{Binding DisplayName}" />
                                                    </StackPanel>
                                                </TreeDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                    </Grid>

                                    <Grid x:Name="SearchPane" IsVisible="False" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="8">
                                        <TextBox x:Name="SearchInFilesTextBox" Classes="sidebar-input" Watermark="Find in files..." />
                                        <TextBox x:Name="ReplaceInFilesTextBox" Grid.Row="1" Classes="sidebar-input" Watermark="Replace with..." />
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                            <CheckBox x:Name="SearchInFilesCaseCheckBox" Content="Case" />
                                            <CheckBox x:Name="SearchInFilesRegexCheckBox" Content="Regex" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6">
                                            <Button x:Name="SearchInFilesSearchButton" Classes="sidebar-action" Content="Search" Click="OnSearchInFilesClick" />
                                            <Button x:Name="SearchInFilesPreviewButton" Classes="sidebar-action" Content="Preview Replace" Click="OnPreviewReplaceInFilesClick" />
                                            <Button x:Name="SearchInFilesReplaceButton" Classes="sidebar-action" Content="Replace All" Click="OnReplaceInFilesClick" />
                                            <Button x:Name="SearchInFilesCancelButton" Classes="sidebar-action" Content="Cancel" Click="OnCancelSearchInFilesClick" IsEnabled="False" />
                                        </StackPanel>
                                        <TreeView x:Name="SearchInFilesResultsTreeView"
                                                  Grid.Row="4"
                                                  DoubleTapped="OnSearchResultDoubleTapped"
                                                  ToolTip.Tip="Double click to open match">
                                            <TreeView.ItemTemplate>
                                                <TreeDataTemplate x:DataType="app:SearchTreeNode"
                                                                  ItemsSource="{Binding Children}">
                                                    <TextBlock Text="{Binding DisplayText}" />
                                                </TreeDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                        <TextBlock x:Name="SearchInFilesSummaryTextBlock"
                                                   Grid.Row="5"
                                                   Classes="sidebar-meta"
                                                   Text="No search yet." />
                                    </Grid>

                                    <Grid x:Name="SourceControlPane" IsVisible="False" RowDefinitions="Auto,1.15*,Auto,*,Auto" RowSpacing="6">
                                        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <Button Classes="git-toolbar" Content="Refresh" Click="OnGitRefreshClick" />
                                                        <Button Classes="git-toolbar" Content="Stage All" Click="OnGitStageAllClick" />
                                                        <Button Classes="git-toolbar" Content="Unstage All" Click="OnGitUnstageAllClick" />
                                                        <Button Classes="git-toolbar" Content="Branches..." Click="OnGitSwitchBranchClick" />
                                                        <Button Classes="git-toolbar" Content="New Branch..." Click="OnGitCreateBranchClick" />
                                                        <Button Classes="git-toolbar" Content="Rename Branch..." Click="OnGitRenameBranchClick" />
                                                        <Button Classes="git-toolbar" Content="Delete Branch..." Click="OnGitDeleteBranchClick" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <Button Classes="git-toolbar" Content="Stash..." Click="OnGitStashPushClick" />
                                                        <Button Classes="git-toolbar" Content="Apply Stash..." Click="OnGitStashApplyClick" />
                                                        <Button Classes="git-toolbar" Content="Pop Stash..." Click="OnGitStashPopClick" />
                                                        <Button Classes="git-toolbar" Content="Drop Stash..." Click="OnGitStashDropClick" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                    <Button Classes="git-toolbar icon"
                                                            ToolTip.Tip="Expand all"
                                                            Click="OnGitExpandAllClick">
                                                        <mi:MaterialIcon Kind="ArrowExpandAll" Width="13" Height="13" />
                                                    </Button>
                                                    <Button Classes="git-toolbar icon"
                                                            ToolTip.Tip="Collapse all"
                                                            Click="OnGitCollapseAllClick">
                                                        <mi:MaterialIcon Kind="ArrowCollapseAll" Width="13" Height="13" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock x:Name="GitBranchTextBlock"
                                                       Grid.Row="1"
                                                       Classes="sidebar-meta"
                                                       Text="Branch: unavailable" />
                                            <StackPanel x:Name="GitOperationPanel"
                                                        Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        IsVisible="False">
                                                <TextBlock x:Name="GitOperationTextBlock"
                                                           Classes="sidebar-meta"
                                                           VerticalAlignment="Center"
                                                           Text="" />
                                                <Button x:Name="GitContinueOperationButton"
                                                        Classes="git-toolbar"
                                                        Content="Continue"
                                                        Click="OnGitContinueOperationClick"
                                                        IsVisible="False" />
                                                <Button x:Name="GitAbortOperationButton"
                                                        Classes="git-toolbar"
                                                        Content="Abort"
                                                        Click="OnGitAbortOperationClick"
                                                        IsVisible="False" />
                                            </StackPanel>
                                            <TextBlock x:Name="GitSummaryTextBlock"
                                                       Grid.Row="3"
                                                       Classes="sidebar-meta"
                                                       Text="No git repository detected." />
                                        </Grid>
                                        <TreeView x:Name="GitChangesTreeView"
                                                  Grid.Row="1"
                                                  SelectionChanged="OnGitChangesSelectionChanged"
                                                  Tapped="OnGitChangesTapped"
                                                  DoubleTapped="OnGitChangeDoubleTapped"
                                                  KeyDown="OnGitChangesKeyDown"
                                                  ToolTip.Tip="Click or press Enter to open the Git compare. Use Open File to open the working file directly.">
                                            <TreeView.Styles>
                                                <Style Selector="TreeViewItem">
                                                    <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                                                </Style>
                                            </TreeView.Styles>
                                            <TreeView.ItemTemplate>
                                                <TreeDataTemplate x:DataType="app:GitChangeTreeNode"
                                                                  ItemsSource="{Binding Children}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <StackPanel.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Open File"
                                                                          IsVisible="{Binding CanOpenFile}"
                                                                          Click="OnGitOpenFileFromContextClick" />
                                                                <MenuItem Header="Open Diff"
                                                                          IsVisible="{Binding CanOpenDiff}"
                                                                          Click="OnGitOpenDiffFromContextClick" />
                                                                <MenuItem Header="Accept Ours"
                                                                          IsVisible="{Binding CanAcceptConflictSide}"
                                                                          Click="OnGitAcceptOursFromContextClick" />
                                                                <MenuItem Header="Accept Theirs"
                                                                          IsVisible="{Binding CanAcceptConflictSide}"
                                                                          Click="OnGitAcceptTheirsFromContextClick" />
                                                                <MenuItem Header="{Binding StageMenuHeader}"
                                                                          IsVisible="{Binding CanStage}"
                                                                          Click="OnGitStageFileFromContextClick" />
                                                                <MenuItem Header="Unstage"
                                                                          IsVisible="{Binding CanUnstage}"
                                                                          Click="OnGitUnstageFileFromContextClick" />
                                                                <MenuItem Header="{Binding DiscardMenuHeader}"
                                                                          IsVisible="{Binding CanDiscard}"
                                                                          Click="OnGitDiscardFileFromContextClick" />
                                                            </ContextMenu>
                                                        </StackPanel.ContextMenu>
                                                        <mi:MaterialIcon Width="14" Height="14" Kind="{Binding IconKind}" />
                                                        <TextBlock FontFamily="Consolas, Menlo, monospace"
                                                                   FontWeight="SemiBold"
                                                                   IsVisible="{Binding HasStatus}"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   Text="{Binding Status}" />
                                                        <TextBlock Text="{Binding Name}" />
                                                    </StackPanel>
                                                </TreeDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                        <TextBlock x:Name="GitDiffPreviewTitleTextBlock"
                                                   Grid.Row="2"
                                                   FontWeight="SemiBold"
                                                   Text="Diff Preview" />
                                        <TextBox x:Name="GitDiffPreviewTextBox"
                                                 Grid.Row="3"
                                                 Background="#0B131D"
                                                 BorderBrush="{DynamicResource ChromeBorderBrush}"
                                                 BorderThickness="1"
                                                 Padding="8"
                                                 IsReadOnly="True"
                                                 Text="Select a change to preview its diff. Click to open the Git compare."
                                                 TextWrapping="NoWrap"
                                                 AcceptsReturn="True"
                                                 FontFamily="Consolas, Menlo, monospace"
                                                 FontSize="12" />
                                        <Grid Grid.Row="4" ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="6">
                                            <Button Grid.Column="0"
                                                    x:Name="GitOpenFileButton"
                                                    Classes="git-toolbar"
                                                    MinWidth="84"
                                                    Content="Open File"
                                                    Click="OnGitOpenFileButtonClick" />
                                            <Button Grid.Column="1"
                                                    x:Name="GitOpenDiffButton"
                                                    Classes="git-toolbar"
                                                    MinWidth="84"
                                                    Content="Open Diff"
                                                    Click="OnGitOpenDiffButtonClick" />
                                            <Button Grid.Column="2"
                                                    x:Name="GitCloseDiffButton"
                                                    Classes="git-toolbar"
                                                    MinWidth="84"
                                                    Content="Close Diff"
                                                    IsVisible="False"
                                                    Click="OnGitCloseDiffButtonClick" />
                                            <Button Grid.Column="3"
                                                    Classes="git-toolbar"
                                                    MinWidth="84"
                                                    Content="Commit..."
                                                    Click="OnGitCommitClick" />
                                        </Grid>
                                    </Grid>

                                    <Grid x:Name="DiagnosticsPane" IsVisible="False" RowDefinitions="Auto,*" RowSpacing="8">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                            <TextBlock x:Name="DiagnosticsSummaryTextBlock"
                                                       Grid.Column="0"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Text="No diagnostics." />
                                            <Button Grid.Column="1"
                                                    Classes="sidebar-action"
                                                    Content="Prev"
                                                    Click="OnPreviousDiagnosticClick" />
                                            <Button Grid.Column="2"
                                                    Classes="sidebar-action"
                                                    Content="Next"
                                                    Click="OnNextDiagnosticClick" />
                                        </Grid>
                                        <ListBox x:Name="DiagnosticsListBox"
                                                 Grid.Row="1"
                                                 SelectionChanged="OnDiagnosticsSelectionChanged"
                                                 DoubleTapped="OnDiagnosticsDoubleTapped"
                                                 ToolTip.Tip="Select a diagnostic to jump to its location.">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="6,4">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock FontFamily="Consolas, Menlo, monospace"
                                                                       FontWeight="SemiBold"
                                                                       Text="{ReflectionBinding Severity}" />
                                                            <TextBlock Text="{ReflectionBinding}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>

                                    <Grid x:Name="AiAssistantPane"
                                          IsVisible="False"
                                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
                                          RowSpacing="8">
                                        <TextBlock x:Name="AiAssistantTitleTextBlock"
                                                   Grid.Row="0"
                                                   FontWeight="SemiBold"
                                                   Text="Smart Actions (Local)" />
                                        <TextBlock x:Name="AiAssistantModeTextBlock"
                                                   Grid.Row="1"
                                                   Classes="sidebar-meta"
                                                   TextWrapping="Wrap"
                                                   Text="Deterministic local helpers only. No external model or provider is configured." />
                                        <Border Grid.Row="2"
                                                Padding="8"
                                                CornerRadius="8"
                                                Background="#132033"
                                                BorderBrush="{DynamicResource ChromeBorderBrush}"
                                                BorderThickness="1">
                                            <Grid RowDefinitions="Auto,Auto,Auto"
                                                  ColumnDefinitions="*,*"
                                                  ColumnSpacing="6"
                                                  RowSpacing="6">
                                                <CheckBox x:Name="AiProviderEnabledCheckBox"
                                                          Grid.Row="0"
                                                          Grid.ColumnSpan="2"
                                                          Content="Use OpenAI for Smart Actions"
                                                          Click="OnAiProviderEnabledClick" />
                                                <TextBox x:Name="AiProviderModelTextBox"
                                                         Grid.Row="1"
                                                         Grid.Column="0"
                                                         Classes="sidebar-input"
                                                         Watermark="Model (for example gpt-5-mini)"
                                                         TextChanged="OnAiProviderModelTextChanged" />
                                                <TextBox x:Name="AiProviderApiKeyEnvVarTextBox"
                                                         Grid.Row="1"
                                                         Grid.Column="1"
                                                         Classes="sidebar-input"
                                                         Watermark="API key env var"
                                                         TextChanged="OnAiProviderApiKeyEnvVarTextChanged" />
                                                <TextBox x:Name="AiProviderEndpointTextBox"
                                                         Grid.Row="2"
                                                         Grid.ColumnSpan="2"
                                                         Classes="sidebar-input"
                                                         Watermark="Responses endpoint"
                                                         TextChanged="OnAiProviderEndpointTextChanged" />
                                            </Grid>
                                        </Border>
                                        <Grid Grid.Row="3"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="6">
                                            <ComboBox x:Name="AiScopeComboBox"
                                                      Grid.Column="0"
                                                      Classes="quick-picker"
                                                      MinWidth="170"
                                                      SelectionChanged="OnAiScopeSelectionChanged"
                                                      ToolTip.Tip="Context scope for the local smart action">
                                                <ComboBoxItem Content="Selection only" />
                                                <ComboBoxItem Content="Current file" />
                                                <ComboBoxItem Content="Workspace summary" />
                                            </ComboBox>
                                            <ComboBox x:Name="AiQuickCommandComboBox"
                                                      Grid.Column="1"
                                                      Classes="quick-picker"
                                                      MinWidth="170"
                                                      SelectionChanged="OnAiQuickCommandSelectionChanged"
                                                      ToolTip.Tip="Quick action for local runs">
                                                <ComboBoxItem Content="Auto (from prompt)" />
                                                <ComboBoxItem Content="/explain" />
                                                <ComboBoxItem Content="/refactor" />
                                                <ComboBoxItem Content="/fix" />
                                                <ComboBoxItem Content="/tests" />
                                                <ComboBoxItem Content="/commit" />
                                            </ComboBox>
                                        </Grid>
                                        <TextBox x:Name="AiPromptTextBox"
                                                 Grid.Row="4"
                                                 Classes="sidebar-input"
                                                 KeyDown="OnAiPromptKeyDown"
                                                 Watermark="Describe the local smart action to run..." />
                                        <WrapPanel Grid.Row="5" Orientation="Horizontal">
                                            <Button Classes="sidebar-action" Content="Run" Click="OnAiAskClick" />
                                            <Button Classes="sidebar-action" Content="Explain" Click="OnAiExplainClick" />
                                            <Button Classes="sidebar-action" Content="Refactor" Click="OnAiRefactorClick" />
                                            <Button Classes="sidebar-action" Content="Fix diagnostics" Click="OnAiFixDiagnosticsClick" />
                                            <Button Classes="sidebar-action" Content="Generate tests" Click="OnAiGenerateTestsClick" />
                                            <Button Classes="sidebar-action" Content="Commit msg" Click="OnAiCommitMessageClick" />
                                            <Button Classes="sidebar-action" Content="Cancel" Click="OnAiCancelClick" />
                                        </WrapPanel>
                                        <WrapPanel Grid.Row="6" Orientation="Horizontal">
                                            <Button Classes="sidebar-action" Content="Copy output" Click="OnAiCopyOutputClick" />
                                            <Button Classes="sidebar-action" Content="Insert at cursor" Click="OnAiInsertOutputClick" />
                                            <Button Classes="sidebar-action" Content="Replace selection" Click="OnAiReplaceSelectionWithOutputClick" />
                                            <Button Classes="sidebar-action" Content="Clear output" Click="OnAiClearOutputClick" />
                                        </WrapPanel>
                                        <TextBlock x:Name="AiAssistantStatusTextBlock"
                                                   Grid.Row="7"
                                                   Classes="sidebar-meta"
                                                   Text="Local smart actions only. Select code and press Ctrl/Cmd+K." />
                                        <Grid Grid.Row="8" RowDefinitions="*,Auto,Auto" RowSpacing="6">
                                            <TextBox x:Name="AiOutputTextBox"
                                                     Grid.Row="0"
                                                     Background="#0F1720"
                                                     BorderBrush="{DynamicResource ChromeBorderBrush}"
                                                     BorderThickness="1"
                                                     FontFamily="Consolas, Menlo, monospace"
                                                     FontSize="12"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     IsReadOnly="True"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                     Text="Local smart-action output will appear here." />
                                            <TextBlock Grid.Row="1"
                                                       Classes="sidebar-meta"
                                                       Text="Recent runs" />
                                            <ComboBox x:Name="AiHistoryComboBox"
                                                      Grid.Row="2"
                                                      Classes="quick-picker"
                                                      MinWidth="220"
                                                      SelectionChanged="OnAiHistorySelectionChanged"
                                                      ToolTip.Tip="Recent smart-action runs in this session" />
                                        </Grid>
                                    </Grid>

                                    <ScrollViewer x:Name="SettingsPane"
                                                  IsVisible="False"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Theme" FontWeight="SemiBold" />
                                            <ComboBox x:Name="SettingsThemeComboBox" SelectionChanged="OnSettingsThemeSelectionChanged">
                                                <ComboBoxItem Content="Dark+" />
                                                <ComboBoxItem Content="One Dark" />
                                                <ComboBoxItem Content="Monokai" />
                                                <ComboBoxItem Content="Light" />
                                            </ComboBox>

                                            <TextBlock Text="Language Mode" FontWeight="SemiBold" />
                                            <ComboBox x:Name="SettingsLanguageComboBox" SelectionChanged="OnSettingsLanguageSelectionChanged">
                                                <ComboBoxItem Content="Auto" />
                                                <ComboBoxItem Content="Plain Text" />
                                                <ComboBoxItem Content="C#" />
                                                <ComboBoxItem Content="JSON" />
                                                <ComboBoxItem Content="XML" />
                                                <ComboBoxItem Content="YAML" />
                                                <ComboBoxItem Content="Markdown" />
                                                <ComboBoxItem Content="JavaScript" />
                                                <ComboBoxItem Content="TypeScript" />
                                                <ComboBoxItem Content="Python" />
                                                <ComboBoxItem Content="SQL" />
                                                <ComboBoxItem Content="HTML" />
                                                <ComboBoxItem Content="CSS" />
                                            </ComboBox>

                                            <TextBlock Text="Editor Font Size" FontWeight="SemiBold" />
                                            <Slider x:Name="SettingsFontSizeSlider"
                                                    Minimum="8"
                                                    Maximum="48"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="OnSettingsFontSizeChanged" />

                                            <CheckBox x:Name="SettingsWordWrapCheckBox" Content="Word Wrap" Click="OnSettingsWordWrapClick" />
                                            <CheckBox x:Name="SettingsMiniMapCheckBox" Content="Mini Map" Click="OnSettingsMiniMapClick" />
                                            <CheckBox x:Name="SettingsFoldingCheckBox" Content="Code Folding" Click="OnSettingsFoldingClick" />
                                            <CheckBox x:Name="SettingsShowAllCharactersCheckBox" Content="Show all characters" Click="OnSettingsShowAllCharactersClick" />

                                            <TextBlock Text="Column Guide" FontWeight="SemiBold" />
                                            <ComboBox x:Name="SettingsColumnGuideComboBox" SelectionChanged="OnSettingsColumnGuideSelectionChanged">
                                                <ComboBoxItem Content="Off" />
                                                <ComboBoxItem Content="80" />
                                                <ComboBoxItem Content="100" />
                                                <ComboBoxItem Content="120" />
                                            </ComboBox>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter x:Name="SidebarWidthSplitter"
                                  Grid.Column="1"
                                  Width="6"
                                  Background="#233545"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  PointerReleased="OnSidebarWidthSplitterPointerReleased" />

                    <Border x:Name="LineNumberGutter"
                            Grid.Column="2"
                            Padding="4,10,8,10"
                            BorderThickness="0,0,1,0"
                            BorderBrush="{DynamicResource ChromeBorderBrush}"
                            Background="#111821"
                            ClipToBounds="True">
                        <Grid ColumnDefinitions="18,*" ColumnSpacing="6">
                            <Canvas x:Name="GitDiffMarkerCanvas"
                                    Grid.Column="0"
                                    Width="18"
                                    IsHitTestVisible="False"
                                    ToolTip.Tip="No Git line changes in this file." />
                            <TextBlock x:Name="LineNumbersTextBlock"
                                       Grid.Column="1"
                                       FontSize="{Binding EditorFontSize}"
                                       Opacity="0.62"
                                       TextAlignment="Right"
                                       Text="1" />
                        </Grid>
                    </Border>

                    <Grid Grid.Column="3" x:Name="EditorHostGrid" ColumnDefinitions="*,6,*" ClipToBounds="True">
                        <Grid Grid.Column="0" ClipToBounds="True" RowDefinitions="Auto,*">
                            <TextBlock x:Name="PrimaryEditorTitleTextBlock"
                                       Grid.Row="0"
                                       Margin="8,0,0,4"
                                       Classes="sidebar-meta"
                                       IsVisible="False"
                                       Text="Compare: current" />
                            <Grid Grid.Row="1" ClipToBounds="True">
                                <ae:TextEditor x:Name="EditorTextBox" Classes="editor"
                                         FontSize="{Binding EditorFontSize}"
                                         Foreground="#D4D4D4"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         WordWrap="False"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />

                                <Border x:Name="ColumnGuide"
                                        IsHitTestVisible="False"
                                        Width="2"
                                        HorizontalAlignment="Left"
                                        Background="#8FD3FF"
                                        Opacity="0.75" />
                            </Grid>
                        </Grid>

                        <GridSplitter x:Name="EditorSplitSplitter"
                                      Grid.Column="1"
                                      Width="6"
                                      Background="#2A3A4A"
                                      ResizeDirection="Columns"
                                      ResizeBehavior="PreviousAndNext"
                                      IsVisible="False" />

                        <Grid x:Name="SplitEditorPane"
                              Grid.Column="2"
                              RowDefinitions="Auto,*"
                              IsVisible="False"
                              DragDrop.AllowDrop="True"
                              DragDrop.DragOver="OnSplitEditorDragOver"
                              DragDrop.Drop="OnSplitEditorDrop">
                            <TextBlock x:Name="SplitEditorTitleTextBlock"
                                       Grid.Row="0"
                                       Margin="8,0,0,4"
                                       Classes="sidebar-meta"
                                       IsVisible="False"
                                       Text="Split: current tab" />
                            <ae:TextEditor x:Name="SplitEditorTextBox"
                                           Grid.Row="1"
                                           Classes="editor"
                                           FontSize="{Binding EditorFontSize}"
                                           Foreground="#D4D4D4"
                                           BorderThickness="0"
                                           Background="Transparent"
                                           WordWrap="False"
                                           DragDrop.AllowDrop="True"
                                           DragDrop.DragOver="OnSplitEditorDragOver"
                                           DragDrop.Drop="OnSplitEditorDrop"
                                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                                           ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ae:TextEditor.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open File In Split..." Click="OnSplitOpenFileClick" />
                                            </ContextMenu>
                                </ae:TextEditor.ContextMenu>
                            </ae:TextEditor>
                        </Grid>

                        <Border x:Name="SplitCompareEmptyStateOverlay"
                                Grid.ColumnSpan="3"
                                IsVisible="False"
                                IsHitTestVisible="False"
                                Background="#55000000">
                            <TextBlock x:Name="SplitCompareEmptyStateTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Opacity="0.88"
                                       Text="No differences in split compare" />
                        </Border>
                    </Grid>

                    <Border x:Name="MiniMapPane"
                            Grid.Column="4"
                            Width="120"
                            BorderThickness="1,0,0,0"
                            BorderBrush="{DynamicResource ChromeBorderBrush}"
                            Background="#101923"
                            IsVisible="True"
                            PointerPressed="OnMiniMapPointerPressed"
                            SizeChanged="OnMiniMapPaneSizeChanged">
                        <ScrollViewer x:Name="MiniMapScrollViewer"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <TextBlock x:Name="MiniMapTextBlock"
                                           FontFamily="Consolas, Menlo, monospace"
                                           FontSize="4.2"
                                           LineHeight="6"
                                           Opacity="0.55"
                                           TextWrapping="NoWrap"
                                           Text="mini map" />
                                <Canvas x:Name="MiniMapDiffOverlay"
                                        IsHitTestVisible="False" />
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <GridSplitter x:Name="TerminalHeightSplitter"
                              Grid.Row="2"
                              Height="6"
                              Background="#233545"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              PointerReleased="OnTerminalHeightSplitterPointerReleased"
                              IsVisible="False" />

                <Border x:Name="TerminalPane"
                        Grid.Row="3"
                        IsVisible="False"
                        Padding="0"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource ChromeBorderBrush}"
                        Background="#0F1722">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Padding="10,6"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource ChromeBorderBrush}"
                                Background="#132033">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" RowSpacing="4">
                                <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Shell Session" />
                                <TextBlock x:Name="TerminalCwdTextBlock"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           FontSize="11"
                                           Opacity="0.72"
                                           VerticalAlignment="Center"
                                           Text="" />
                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="TerminalInterruptButton"
                                            Classes="sidebar-action"
                                            Content="Interrupt"
                                            Click="OnTerminalInterruptClick" />
                                    <Button x:Name="TerminalRestartButton"
                                            Classes="sidebar-action"
                                            Content="Restart"
                                            Click="OnTerminalRestartClick" />
                                    <Button x:Name="TerminalClearButton" Classes="sidebar-action" Content="Clear" Click="OnTerminalClearClick" />
                                    <Button Classes="sidebar-action" Content="Hide" Click="OnToggleTerminalClick" />
                                </StackPanel>
                                <TextBlock x:Name="TerminalStateTextBlock"
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           FontSize="11"
                                           Opacity="0.78"
                                           Text="No active shell session. Send a command to start one." />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           FontSize="11"
                                           Opacity="0.72"
                                           Text="Persistent shell state across commands. PTY-backed on Unix when the system script wrapper is available and on Windows when ConPTY is supported. Common VT line rewriting, cursor addressing, and clear-screen output are supported. Alternate-screen apps render inline, but full VT coverage and full-screen terminal fidelity are still incomplete. Esc or Ctrl/Cmd+C interrupts the foreground command, Ctrl/Cmd+L clears, Restart resets the session." />
                            </Grid>
                        </Border>

                        <TextBox x:Name="TerminalOutputTextBox"
                                 Margin="8,8,8,0"
                                 Background="#0B131D"
                                 BorderBrush="{DynamicResource ChromeBorderBrush}"
                                 BorderThickness="1"
                                 Padding="8"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Menlo, monospace"
                                 FontSize="12" />

                        <Border DockPanel.Dock="Bottom"
                                Margin="8,8,8,8"
                                Padding="0"
                                Background="Transparent">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox x:Name="TerminalInputTextBox"
                                         Grid.Column="0"
                                         Classes="sidebar-input"
                                         Watermark="Send a command to the current shell session..."
                                         KeyDown="OnTerminalInputKeyDown" />
                                <Button x:Name="TerminalSendButton"
                                        Grid.Column="1"
                                        Classes="sidebar-action"
                                        Content="Send"
                                        Click="OnTerminalSendClick" />
                            </Grid>
                        </Border>
                    </DockPanel>
                </Border>

                <Button x:Name="EditorMaximizeOverlayButton"
                        Grid.Row="1"
                        Margin="0,10,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        IsVisible="False"
                        Classes="quick-chip"
                        Click="OnToggleEditorMaximizeClick"
                        ToolTip.Tip="Restore editor layout (F11)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Width="14"
                                         Height="14"
                                         Foreground="{DynamicResource ToolbarIconBrush}"
                                         Kind="FullscreenExit" />
                        <TextBlock Text="Restore Layout" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </DockPanel>
</Window>
